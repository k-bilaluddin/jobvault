# ─────────────────────────────────────────
# Auth (required)
# ─────────────────────────────────────────
# Owner account credentials
Auth__Email=bilal@jobvault.dev
Auth__PasswordHash=           # bcrypt hash — run: cd tools/HashPassword && dotnet run
Auth__JwtSecret=              # min 32 chars — e.g. openssl rand -hex 32
Auth__TokenExpiryDays=7

# Demo account (optional — leave empty to disable)
Demo__Email=demo@jobvault.dev
Demo__PasswordHash=           # bcrypt hash of demo password

# ─────────────────────────────────────────
# CORS (required)
# ─────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://jobvault.kbilaluddin.dev,https://mock.kbilaluddin.dev,http://localhost:5173

# ─────────────────────────────────────────
# MongoDB (required)
# ─────────────────────────────────────────
MongoDb__ConnectionString=mongodb+srv://...
MongoDb__DatabaseName=jobvault
MongoDb__JobApplicationsCollectionName=JobApplications
MongoDb__NotificationsCollectionName=notifications

# ─────────────────────────────────────────
# RabbitMQ / CloudAMQP (required)
# ─────────────────────────────────────────
RabbitMq__ConnectionString=amqps://...
RabbitMq__ExchangeName=job.applications
RabbitMq__DeadLetterExchangeName=job.applications.dead
RabbitMq__DeadLetterQueueName=job.applications.dlq
RabbitMq__JobApplicationCreatedQueueName=job.applications.created
RabbitMq__JobApplicationUpdatedQueueName=job.applications.updated
RabbitMq__JobApplicationReceivedQueueName=job.applications.received
RabbitMq__SseNotificationsQueueName=job.applications.notifications

# ─────────────────────────────────────────
# Telegram (required)
# ─────────────────────────────────────────
Telegram__BotToken=
Telegram__ChatId=

# ─────────────────────────────────────────
# GitHub vault (required)
# ─────────────────────────────────────────
GitHub__Token=                # PAT with repo scope
GitHub__Owner=k-bilaluddin
GitHub__Repository=job-applications-vault
GitHub__Branch=master
GitHub__CvFileName=KhawajaBilal_Uddin_CV
GitHub__CoverLetterFileName=KhawajaBilal_Uddin_CoverLetter

# ─────────────────────────────────────────
# Document generation service (optional — defaults shown)
# ─────────────────────────────────────────
DocumentGeneration__BaseUrl=http://jobvault-generation-service:3000

# ─────────────────────────────────────────
# LibreOffice (optional — override for local Windows dev)
# ─────────────────────────────────────────
# LibreOffice__ExecutablePath=C:\Program Files\LibreOffice\program\soffice.exe
