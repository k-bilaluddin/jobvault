# ─────────────────────────────────────────
# Auth (required)
# ─────────────────────────────────────────
AUTH_EMAIL=bilal@jobvault.dev
AUTH_PASSWORD_HASH=           # bcrypt hash — run: cd tools/HashPassword && dotnet run
AUTH_JWT_SECRET=              # min 32 chars — e.g. openssl rand -hex 32
AUTH_TOKEN_EXPIRY_DAYS=7

# Demo account (optional — leave empty to disable)
DEMO_EMAIL=demo@jobvault.dev
DEMO_PASSWORD_HASH=           # bcrypt hash of demo password

# ─────────────────────────────────────────
# CORS (required)
# ─────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://jobvault.kbilaluddin.dev,https://mock.kbilaluddin.dev,http://localhost:5173

# ─────────────────────────────────────────
# MongoDB (required)
# ─────────────────────────────────────────
MONGODB_CONNECTION_STRING=mongodb+srv://...
MONGODB_DATABASE_NAME=jobvault
MONGODB_JOB_APPLICATIONS_COLLECTION=JobApplications
MONGODB_NOTIFICATIONS_COLLECTION=notifications

# ─────────────────────────────────────────
# RabbitMQ / CloudAMQP (required)
# ─────────────────────────────────────────
RABBITMQ_CONNECTION_STRING=amqps://...
RABBITMQ_EXCHANGE_NAME=job.applications
RABBITMQ_DEAD_LETTER_EXCHANGE_NAME=job.applications.dead
RABBITMQ_DEAD_LETTER_QUEUE_NAME=job.applications.dlq
RABBITMQ_JOB_APPLICATION_CREATED_QUEUE=job.applications.created
RABBITMQ_JOB_APPLICATION_UPDATED_QUEUE=job.applications.updated
RABBITMQ_JOB_APPLICATION_RECEIVED_QUEUE=job.applications.received
RABBITMQ_SSE_NOTIFICATIONS_QUEUE=job.applications.notifications

# ─────────────────────────────────────────
# Telegram (required)
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────
# GitHub vault (required)
# APP_GH_TOKEN avoids conflict with GitHub Actions' built-in GITHUB_TOKEN
# ─────────────────────────────────────────
APP_GH_TOKEN=                 # PAT with repo scope
APP_GH_OWNER=k-bilaluddin
APP_GH_REPOSITORY=job-applications-vault
APP_GH_BRANCH=master
APP_GH_CV_FILE_NAME=KhawajaBilal_Uddin_CV
APP_GH_COVER_LETTER_FILE_NAME=KhawajaBilal_Uddin_CoverLetter

# ─────────────────────────────────────────
# Vault (required — local path to cloned vault repo, mounted into API container)
# ─────────────────────────────────────────
APP_VAULT_ROOT_DIR=             # e.g. /home/user/job-applications-vault

# ─────────────────────────────────────────
# Document generation service (optional — defaults shown)
# ─────────────────────────────────────────
DOCUMENT_GENERATION_BASE_URL=http://jobvault-generation-service:3000

# ─────────────────────────────────────────
# LibreOffice (optional — override for local Windows dev)
# ─────────────────────────────────────────
# LIBREOFFICE_EXECUTABLE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
